PORT=5000
NODE_ENV=production
API_VERSION=v1
DEMO_MODE=true
JWT_SECRET=questup-demo-secret
JWT_EXPIRY=7d
APP_URL=https://your-questup-backend.example.com/api/v1
FRONTEND_URL=https://your-questup-frontend.example.com
CORS_ORIGIN=https://your-questup-frontend.example.com
DATABASE_URL=
ADMIN_EMAIL=admin@questup.local
ADMIN_PASSWORD=123456

# Feature flags
FEATURE_TASK_SUBMISSIONS=true
FEATURE_ADMIN_ACCOUNTS=true
FEATURE_QR_EVENTS=true
FEATURE_QR_DROP_ASSIGNMENTS=true
FEATURE_GIFT_QRS=true
FEATURE_PLUS_MEMBERSHIPS=true
FEATURE_SHOP_APPLICATIONS=true
FEATURE_SUPPORT_TICKETS=true
FEATURE_ADMIN_USERS=true
FEATURE_NOTIFICATIONS=true

# Passwordless & Auth
PASSWORDLESS_CODE_TTL=10
PASSWORDLESS_COOLDOWN=60
PASSWORDLESS_MAX_ATTEMPTS=5

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_ALLOW_SELF_SIGNED=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=QuestUp

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=questup_db
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Google OAuth (Optional, Demo mode will work without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REACT_APP_GOOGLE_WEB_CLIENT_ID=
REACT_APP_GOOGLE_IOS_CLIENT_ID=
REACT_APP_GOOGLE_IOS_SERVER_CLIENT_ID=

# Firebase (Optional, for future mobile app integration)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Third-party
MAPBOX_TOKEN=your_mapbox_token
FCM_PROJECT_ID=your_fcm_project_id
FCM_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
CLOUD_STORAGE_BUCKET=questup-media
